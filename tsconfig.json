{
  "compilerOptions": {
    "target": "esnext",
    "module": "nodenext",
    "checkJs": true,
    "strict": true,
    "jsx": "react-jsx",
    "jsxImportSource": "@kayelaa/zeyah",
    "strictNullChecks": false,
    "moduleResolution": "node16",
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "lib": ["ES2024"],
    "allowJs": true,
    "strictFunctionTypes": true,
    "sourceMap": false,
    "noImplicitAny": true,
    "verbatimModuleSyntax": true,
    "rootDir": "./",
    "outDir": "./dist",
    "forceConsistentCasingInFileNames": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "allowArbitraryExtensions": true,
    "paths": {
      "@zeyah-bot/*": ["./zeyah-bot/*.js", "./zeyah-bot/*/index.js"],
      "@zeyah-utils/*": ["./zeyah-bot/utils/*.js"],
      "@zeyah-utils": ["./zeyah-bot/utils/index.js"],
      "@commands/*": ["./commands/*.js"],
      "@config": ["./zeyah.config.js"],
      "@package": ["./package.json"],
      "@kayelaa/zeyah": ["./zeyah-bot/jsx/index.js"],
      "@kayelaa/zeyah/jsx-runtime": ["./zeyah-bot/jsx/jsx-runtime.js"]
    },
    "types": ["node"]
  },
  "include": ["**/*"],
  "exclude": ["dist", "commands/commands.d.ts"]
}
